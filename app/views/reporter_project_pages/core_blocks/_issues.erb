<% if editable %>
  <div class="contextual">
    <%= link_to_function sprite_icon('settings', l(:label_options)),
                         "$('##{block}-settings').toggle();",
                         class: 'icon-only icon-settings',
                         title: l(:label_options) %>
  </div>
<% end %>

<h3>
  <%= "#{query.project} |" if query.project %>
  <%= link_to query.name, _project_issues_path(query.project, query.as_params) %>
  (<%= issues.size %>)
</h3>

<% if editable %>
  <div id="<%= block %>-settings" style="display:none;">
    <%= form_tag(project_reporter_page_path(project, tab: tab.id), remote: true) do %>
      <div id="list-definition">
        <div class="box">
          <%= render_query_columns_selection(query, name: "settings[#{block}][columns]") %>
        </div>
        <div class="box">
          <p>
            <label>
              <%= l(:label_reporter_items_limit) %>:
              <%= select_tag "settings[#{block}][limit]", reporter_project_limit_options(reporter_project_block_limit(settings)) %>
            </label>
          </p>
          <p>
            <label>
              <%= l(:field_group_by) %>:
              <%= select_tag "settings[#{block}][group_by]",
                             reporter_project_group_by_options(query, settings) %>
            </label>
          </p>
        </div>
      </div>
      <p>
        <%= submit_tag l(:button_save) %>
        <%= link_to_function l(:button_cancel), "$('##{block}-settings').toggle();" %>
      </p>
    <% end %>
  </div>
<% end %>

<% if issues.any? %>
  <%= render partial: 'issues/list',
             locals: {
               issues: issues,
               query: query,
               query_options: {
                 sort_param: "settings[#{block}][sort]",
                 sort_link_options: { method: :post, remote: true }
               }
             } %>
<% else %>
  <p class="nodata"><%= l(:label_no_data) %></p>
<% end %>

<% content_for :header_tags do %>
<%= auto_discovery_link_tag(:atom,
                            _project_issues_path(query.project, query.as_params.merge(format: 'atom', key: User.current.atom_key)),
                            title: query.name) %>
<% end %>
